{
  "name": "pomelo-pw",
  "version": "0.1.1",
  "description": "Flow-based UI automation tool powered by Playwright",
  "command": "pomelo-pw",
  "userInvocable": true,
  "alwaysAllow": false,
  "categories": ["automation", "testing", "browser"],
  "examples": [
    {
      "description": "Run a flow file",
      "command": "pomelo-pw run flows/example.yaml"
    },
    {
      "description": "Run with verbose output",
      "command": "pomelo-pw run flows/example.yaml -v"
    },
    {
      "description": "Validate a flow",
      "command": "pomelo-pw validate flows/example.yaml"
    },
    {
      "description": "List available steps",
      "command": "pomelo-pw steps"
    },
    {
      "description": "Show step specification",
      "command": "pomelo-pw spec navigate"
    }
  ]
}
